; enable RTC
ASM
; enable LSE (32.768 kHz oscillator)
BTJT (CLK_ECKCR), CLK_ECKCR_LSEON_POS, ::__LBL_LSE_RDY
BSET (CLK_ECKCR), CLK_ECKCR_LSEON_POS

:::__LBL_WAIT_LSE_RDY
BTJF (CLK_ECKCR), CLK_ECKCR_LSERDY_POS, ::__LBL_WAIT_LSE_RDY

:::__LBL_LSE_RDY
BTJT (CLK_CRTCR), CLK_CRTCR_RTCSWBSY_POS, ::__LBL_LSE_RDY
; select LSE as RTC clock source
MOV (CLK_CRTCR), CLK_CRTCR_RTCSEL_LSE
; enable SYSCLK clock to RTC
BSET (CLK_PCKENR2), CLK_PCKENR2_RTC_POS
ENDASM