ASM
.IF {!XOROUT_TYPE} == I
XORI A0, A0, {!XOROUT_VALUE}
.ELIF {!XOROUT_TYPE} == M
LBU T1, {!XOROUT_VALUE}
XOR A0, A0, T1 ;{!XOROUT_VALUE}
.ELIF {!XOROUT_TYPE} == S
LW T1, {!XOROUT_VALUE}(SP)
XOR A0, A0, T1 ;{!XOROUT_VALUE}
.ENDIF ;{!XOROUT_TYPE}

:::__LBL_WAIT_SPI_TXE
LHU T1, SPI1_STATR
ANDI T1, T1, SPI1_STATR_TXE
BEQ T1, ZERO, ::__LBL_WAIT_SPI_TXE
SH A0, SPI1_DATAR
ENDASM