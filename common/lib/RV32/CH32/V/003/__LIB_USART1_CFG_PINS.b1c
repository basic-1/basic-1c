INI,__LIB_USART1_OPT

ASM
LBU A0, __LIB_USART1_OPT
ANDI A0, A0, 4 ; RX bit
BEQ A0, ZERO, ::__LBL_NO_RX
ENDASM

; RX
IOCTL,"PD"<STRING>,"CFGPIN6"<STRING>,"IN_PULLUP_NOEXTI"<STRING>

ASM
:::__LBL_NO_RX
LBU A0, __LIB_USART1_OPT
ANDI A0, A0, 8 ; TX bit
BEQ A0, ZERO, ::__LBL_NO_TX
ENDASM

; TX
IOCTL,"PD"<STRING>,"CFGPIN5"<STRING>,"OUTMP_PUSHPULL_FAST"<STRING>

ASM
:::__LBL_NO_TX
ENDASM
