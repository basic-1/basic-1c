INI,__LIB_USART1_OPT

; stop USART1
:__LIB_USART1_7_CALL
ASM
LBU A0, __LIB_USART1_OPT
ANDI A0, A0, 0x8 ; TX bit
BEQ A0, ZERO, ::__LBL_USART_STOP ; simplex RX mode

:::__LBL_WAIT_TC
LW A0, USART1_STATR
ANDI A0, A0, USART1_STATR_TC
BEQ A0, ZERO, ::__LBL_WAIT_TC

:::__LBL_USART_STOP
SW ZERO, USART1_CTLR1
RET
ENDASM
