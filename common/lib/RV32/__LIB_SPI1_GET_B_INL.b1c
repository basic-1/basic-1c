USES,S0
ASM
:::__LBL_WAIT_SPI_RXNE
LHU A0, SPI1_STATR
ANDI A0, A0, SPI1_STATR_RXNE
BEQ A0, ZERO, ::__LBL_WAIT_SPI_RXNE
LHU S0, SPI1_DATAR

.IF {!XORIN_TYPE} == I
XORI S0, S0, {!XORIN_VALUE}
.ELIF {!XORIN_TYPE} == M
LBU A0, {!XORIN_VALUE}
XOR S0, S0, A0 ;{!XORIN_VALUE}
.ELIF {!XORIN_TYPE} == S
LW A0, {!XORIN_VALUE}(SP)
XOR S0, S0, A0 ;{!XORIN_VALUE}
.ENDIF ;{!XORIN_TYPE}
ENDASM
