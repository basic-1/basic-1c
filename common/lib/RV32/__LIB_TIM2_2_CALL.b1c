; TIM2 PERIODMS <value>
; A1 - period in ms

INI,__LIB_CPU_OPT

GA,__LIB_TIM2_PSC_DATA,WORD(C),0<BYTE>,3<BYTE>
DAT,__LIB_TIM2_PSC_DATA,8000<WORD>,16000<WORD>,24000<WORD>,48000<WORD>

:__LIB_TIM2_2_CALL
ASM
LBU A0, __LIB_CPU_OPT
SLLI A0, A0, 1
LHU T1, __LIB_TIM2_PSC_DATA(A0)
ADDI A0, A1, -1
BNE A0, ZERO, ::__LBL_SET_REGS
LI A0, 1
SRLI T1, T1, 1

:::__LBL_SET_REGS
SH A0, TIM2_ATRLR
ADDI T1, T1, -1
SH T1, TIM2_PSC
RET
ENDASM