; returns the right part of a string
; A1 - string address, A2 - characters to return, returns substring in A0
:__LIB_STR_RIGHT
ASM
ADDI SP, SP, -16
SW A3, 8(SP)
SW A2, 4(SP)
SW RA, 0(SP)

LI A0, 0
BEQ A1, ZERO, ::__LBL_NULL_STR
LBU A0, 1(A1)

:::__LBL_NULL_STR
SUB A2, A0, A2
BGE A2, ZERO, ::__LBL_N_OK
LI A2, 0

:::__LBL_N_OK
ADDI A2, A2, 1
LI A3, B1C_MAX_STR_LEN
CALL __LIB_STR_MID

LW RA, 0(SP)
LW A2, 4(SP)
LW A3, 8(SP)
ADDI SP, SP, 16
RET
ENDASM