; SPI WAIT RXNE/TXE/NOTBSY
ASM
.IF {VALUE} == 0
:::__LBL_WAIT_SPI_RXNE
LHU A0, SPI1_STATR
ANDI A0, A0, SPI1_STATR_RXNE
BEQ A0, ZERO, ::__LBL_WAIT_SPI_RXNE
.ELIF {VALUE} == 1
:::__LBL_WAIT_SPI_TXE
LHU A0, SPI1_STATR
ANDI A0, A0, SPI1_STATR_TXE
BEQ A0, ZERO, ::__LBL_WAIT_SPI_TXE
.ELSE
:::__LBL_WAIT_SPI_BSY
LHU A0, SPI1_STATR
ANDI A0, A0, SPI1_STATR_BSY
BNE A0, ZERO, ::__LBL_WAIT_SPI_BSY
.ENDIF
ENDASM